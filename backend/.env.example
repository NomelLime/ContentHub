# ContentHub — пример конфига (.env.example → .env)

# Пути к проектам (заполни если не стандартные)
# GITHUB_ROOT=C:\Users\lemon\Documents\GitHub

# JWT секрет (обязательно поменяй в продакшне!)
CONTENTHUB_SECRET_KEY=change-me-to-random-32-char-string

# Порт и хост
CONTENTHUB_HOST=0.0.0.0
CONTENTHUB_PORT=8000

# Интервалы обновления
METRICS_REFRESH_SEC=60
WS_BROADCAST_SEC=5

# JWT сроки
ACCESS_TOKEN_EXPIRE_MIN=60
REFRESH_TOKEN_EXPIRE_DAYS=30
