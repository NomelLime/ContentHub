# Скопируйте в .env и подставьте значения. Часть секретов может быть в GitHub/.secrets.env (загружается раньше).

GITHUB_ROOT=C:\path\to\GitHub

# PreLend Internal API (после SSH-туннеля на порт 9090)
PL_INTERNAL_API_URL=http://127.0.0.1:9090
# Тот же ключ, что у процесса prelend-internal-api на VPS (PL_INTERNAL_API_KEY в /run/prelend.env или unit).
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
PL_INTERNAL_API_KEY=

# Локальная разработка без VPS: чтение/запись только в клон PreLend на диске (без сверки с API)
# CONTENTHUB_PL_TRUST_LOCAL_FALLBACK=1

# Для ContentHub\run-all.ps1 — автозапуск туннеля (OpenSSH)
# CH_TUNNEL_TARGET=user@your-vps-hostname
