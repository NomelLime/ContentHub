# Скопируйте в tunnel.local.env (не коммитится: маска *.local.env в корне монорепы).
# Те же CH_TUNNEL_* что в run-all.shareable.cmd / run-all.local.cmd — для PowerShell-лаунчеров.

CH_TUNNEL_TOOL=plink
CH_TUNNEL_HOST=your.vps.host.or.ip
CH_TUNNEL_USER=root
CH_TUNNEL_PASSWORD=PUT_PASSWORD_HERE

# Альтернатива plink — один target для ssh (если задан, plink-блок в скрипте не используется):
# CH_TUNNEL_TARGET=ubuntu@203.0.113.10
